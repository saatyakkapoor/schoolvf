# Copy to `.env` in this folder: `cp .env.example .env` then edit.
# Vision worker (OCR) + API (MJPEG Live Monitor) both use this when set.
# Vision: real RTSP only (no mock) unless you set PLATE_ENGINE=mock.

# Hikvision RTSP (main stream); admin / abcd@1234 — encode @ as %40
CAMERA_RTSP_URL=rtsp://admin:abcd%401234@192.168.1.12:554/Streaming/Channels/101
INTERNAL_INGEST_SECRET=dev-ingest-secret

# Exit gate worker: must match GET /api/cameras (cam-exit-1) or Live hides rows for that tab.
CAMERA_ID=cam-exit-1
CAMERA_NAME=Exit gate — Main

# Vision pipeline: sample = YOLO + OpenCV + EasyOCR (see sample.txt). rapid = RapidOCR only.
VISION_STACK=sample
# detection = log plate regions only, no OCR. recognition = EasyOCR on crops.
PLATE_STAGE=recognition
PLATE_DETECT_MIN_QUALITY_FOR_OCR=0.2
# Large heuristic crops + Easy full-frame often repeat the same false plate; enable only if needed.
PLATE_USE_HEURISTIC_BANDS=false
SAMPLE_EASY_OCR_FULLFRAME_FALLBACK=false
OCR_GPU=false

# Throughput: 0 = no sleep between frames (CPU-bound by YOLO/EasyOCR). Match thread counts to CPUs you give Docker.
PROCESS_INTERVAL_SEC=0
OMP_NUM_THREADS=16
TORCH_NUM_THREADS=16
OPENCV_NUM_THREADS=16
HTTP_POST_WORKERS=16
# NVIDIA + CUDA image only: YOLO_DEVICE=cuda:0 YOLO_HALF=true
# Smaller = faster YOLO: YOLO_IMGSZ=320

# Optional: path to custom plate detector weights (default looks for apps/vision-worker/models/license_plate_detector.pt)
# YOLO_PLATE_MODEL=/app/apps/vision_worker/models/license_plate_detector.pt

# If the container cannot reach a LAN camera, use Docker host networking or fix routing;
# from Docker Desktop, the VM must reach 192.168.x.x (sometimes needs extra_hosts / host mode).
