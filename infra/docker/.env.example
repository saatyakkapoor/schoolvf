# Copy to `.env` in this folder: `cp .env.example .env` then edit.
# Vision worker (OCR) + API (MJPEG Live Monitor) both use this when set.
# Vision: real RTSP only (no mock) unless you set PLATE_ENGINE=mock.

# --- LAN hosting -----------------------------------------------------
# All published ports already bind to 0.0.0.0, so any device on the
# same network can reach the stack at http://<HOST_IP>:<PORT>.
# `scripts/dev/start-all.sh` auto-detects the host's primary LAN IP and
# prints the URLs; export HOST_IP to override the detection (useful on
# multi-NIC hosts or when the script picks the wrong interface).
# HOST_IP=192.168.1.50
# DASHBOARD_PORT=3000
# API_PORT=8000
# ---------------------------------------------------------------------

# Hikvision RTSP (main stream); admin / abcd@1234 — encode @ as %40
CAMERA_RTSP_URL=rtsp://admin:abcd%401234@192.168.1.12:554/Streaming/Channels/101
INTERNAL_INGEST_SECRET=dev-ingest-secret

# Exit gate worker: must match GET /api/cameras (cam-exit-1) or Live hides rows for that tab.
CAMERA_ID=cam-exit-1
CAMERA_NAME=Exit gate — Main

# Vision pipeline: sample = YOLO + OpenCV + EasyOCR (see sample.txt). rapid = RapidOCR only.
VISION_STACK=sample
# detection = log plate regions only, no OCR. recognition = EasyOCR on crops.
PLATE_STAGE=recognition
PLATE_DETECT_MIN_QUALITY_FOR_OCR=0.2
# Large heuristic crops + Easy full-frame often repeat the same false plate; enable only if needed.
PLATE_USE_HEURISTIC_BANDS=false
SAMPLE_EASY_OCR_FULLFRAME_FALLBACK=false

# --- GPU --------------------------------------------------------------
# To enable GPU (NVIDIA T1000 / RTX etc.):
#   1. Install nvidia-container-toolkit on the host
#        Linux: sudo apt install nvidia-container-toolkit && sudo nvidia-ctk runtime configure --runtime=docker && sudo systemctl restart docker
#        Windows: install latest NVIDIA driver, then enable WSL2 GPU support in Docker Desktop > Settings > Resources > WSL Integration
#   2. Uncomment the line below to switch the worker image to the CUDA build:
# DOCKERFILE_VISION=infra/docker/Dockerfile.vision.cuda
#
# All three default to `auto`: the worker runs on CUDA + FP16 when a GPU
# is detected, otherwise CPU. Force a value if you need to pin behaviour.
OCR_GPU=auto
YOLO_DEVICE=auto
YOLO_HALF=auto
# 640 = fastest CPU; 960 = balanced; 1280/1536 = high recall (1536 = default in code for CUDA).
# If GPU latency spikes, try 1280.
YOLO_IMGSZ=1536

# Min width to upscale each plate crop before EasyOCR (higher = sharper but slower).
# PLATE_OCR_TARGET_MIN_WIDTH=720
# Plate recall tunables (sample stack): wider bumper crop / more YOLO candidates / more OCR tries per frame.
# VEHICLE_BUMPER_TOP_FRAC=0.34
# PLATE_YOLO_MIN_CONF=0.06
# PLATE_OCR_BUDGET=10
# MIN_CONFIDENCE=0.065

# Hard floor for posting reads to the dashboard. Anything under this
# combined-confidence is treated as noise and never surfaces. Set 0 to
# disable (accept every read that passes recognition).
INGEST_MIN_CONFIDENCE=0.50

# Gate: seconds after a vehicle first appears before plate+route OCR runs (latest sharp frame).
# Grabber thread keeps draining RTSP so backlog does not grow; use 0 to disable wait.
GATE_VEHICLE_SETTLE_SEC=1.0
# OCR futures pool (prefetch / multi-camera). Raise if GPU waits on thread scheduling.
OCR_POOL_WORKERS=8

# Throughput: 0 = no sleep between frames (CPU-bound by YOLO/EasyOCR). Match thread counts to CPUs you give Docker.
PROCESS_INTERVAL_SEC=0
OMP_NUM_THREADS=16
TORCH_NUM_THREADS=16
OPENCV_NUM_THREADS=16
HTTP_POST_WORKERS=16

# Optional: path to custom plate detector weights (default looks for apps/vision-worker/models/license_plate_detector.pt)
# YOLO_PLATE_MODEL=/app/apps/vision_worker/models/license_plate_detector.pt

# If the container cannot reach a LAN camera, use Docker host networking or fix routing;
# from Docker Desktop, the VM must reach 192.168.x.x (sometimes needs extra_hosts / host mode).
